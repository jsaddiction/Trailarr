######################################
#                                    #
#       Trailarr Config File         #
#                                    #
######################################

[LOGS]
log_level: INFO

[TRAILERS]
# Maximum resolution for trailer downloads (360, 480, 720, 1080, 2160)
# Default: 1080 (Full HD)
# Set to 2160 for 4K trailers (larger file sizes)
max_resolution: 1080

[YT_DLP]
# Optional URL of a bgutil-ytdlp-pot-provider HTTP service used to mint
# YouTube Proof-of-Origin tokens. If set and reachable at startup,
# trailarr passes the appropriate yt-dlp extractor-args so trailer
# downloads survive YouTube's bot-detection. Leave blank to disable.
# See: https://github.com/Brainicism/bgutil-ytdlp-pot-provider
pot_provider_url:

[KODI]
kodi_name: 
kodi_ip: 127.0.0.1
kodi_port: 8080
kodi_user: 
kodi_pass: 
kodi_notify: True