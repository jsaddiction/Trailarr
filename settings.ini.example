######################################
#                                    #
#       Trailarr Config File         #
#                                    #
######################################

[LOGS]
log_level: INFO

[TRAILERS]
# Maximum resolution for trailer downloads (360, 480, 720, 1080, 2160)
# Default: 1080 (Full HD)
# Set to 2160 for 4K trailers (larger file sizes)
max_resolution: 1080

[YT_DLP]
# Optional URL of a bgutil-ytdlp-pot-provider HTTP service used to mint
# YouTube Proof-of-Origin tokens. If set and reachable at startup,
# trailarr passes the appropriate yt-dlp extractor-args so trailer
# downloads survive YouTube's bot-detection. Leave blank to disable.
# See: https://github.com/Brainicism/bgutil-ytdlp-pot-provider
pot_provider_url:

# When a download source (identified by URL host) returns a session-level
# rejection — e.g. YouTube's "Sign in to confirm you're not a bot" — skip
# further downloads from that source for this many minutes. Per-source.
# The first attempt after the window expires probes whether the block has
# cleared; success resumes the source, another rejection resets the timer.
# Default 1440 minutes (24h). Decrease to probe more aggressively, increase
# to be more conservative when a source has flagged your IP.
source_block_minutes: 1440

[KODI]
kodi_name: 
kodi_ip: 127.0.0.1
kodi_port: 8080
kodi_user: 
kodi_pass: 
kodi_notify: True